{
  "manifest_version": 3,
  "name": "DealWatch Companion",
  "version": "0.1.0",
  "description": "Open DealWatch Compare from the current grocery product page and keep the local-first workflow one click away.",
  "minimum_chrome_version": "120",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "contextMenus"
  ],
  "action": {
    "default_title": "DealWatch Companion",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_page": "options.html",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  }
}
