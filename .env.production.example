# DealWatch production/runtime example
# Copy to `.env.production` and replace every __REQUIRED_* value before go-live.

DATABASE_URL=__REQUIRED_DATABASE_URL__
OWNER_EMAIL=__REQUIRED_OWNER_EMAIL__
OWNER_DISPLAY_NAME=DealWatch Owner
OWNER_BOOTSTRAP_TOKEN=__REQUIRED_OWNER_BOOTSTRAP_TOKEN__

# Public URLs
APP_BASE_URL=__REQUIRED_APP_BASE_URL__
# Despite the legacy name, this must be the deployed frontend origin in production.
WEBUI_DEV_URL=__REQUIRED_WEBUI_ORIGIN__

# Store/runtime defaults
ZIP_CODE=__REQUIRED_ZIP_CODE__
WORKER_POLL_SECONDS=60
MAINTENANCE_ENABLED=true
MAINTENANCE_HOUR_LOCAL=3
MAINTENANCE_MINUTE_LOCAL=15
DEFAULT_TASK_CADENCE_MINUTES=360
DEFAULT_NOTIFICATION_COOLDOWN_MINUTES=240
# Temporary SQLite/bootstrap bridge only. PostgreSQL deployments should keep this disabled.
PRODUCT_AUTO_CREATE_SCHEMA=false
ENABLED_STORES=weee
API_HOST=0.0.0.0
API_PORT=8000
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_BLOCK_STYLESHEETS=true
OPERATOR_ARTIFACTS_DIR=.runtime-cache/operator
EXTERNAL_CACHE_DIR=~/.cache/dealwatch
BROWSER_DEBUG_BUNDLE_DIR=.runtime-cache/operator/browser-debug
LOG_MAX_BYTES=1000000
LOG_BACKUP_COUNT=5
LOG_RETENTION_DAYS=14
CACHE_BUDGET_BYTES=4294967296

# Notification path: choose Postmark or SMTP.
POSTMARK_SERVER_TOKEN=__OPTIONAL_POSTMARK_SERVER_TOKEN__
POSTMARK_WEBHOOK_TOKEN=__OPTIONAL_POSTMARK_WEBHOOK_TOKEN__
POSTMARK_FROM_EMAIL=__OPTIONAL_POSTMARK_FROM_EMAIL_IF_USING_POSTMARK__
POSTMARK_MESSAGE_STREAM=outbound

SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=

# Optional integrations
USE_LLM=false
LLM_API_KEY=
PROXY_SERVER=
CHROME_CDP_URL=http://127.0.0.1:9333
CHROME_REMOTE_DEBUG_PORT=9333
CHROME_USER_DATA_DIR=~/.cache/dealwatch/browser/chrome-user-data
CHROME_PROFILE_NAME=dealwatch
CHROME_PROFILE_DIRECTORY=Profile 21
CHROME_ATTACH_MODE=browser
# Optional human-facing browser lane identity hints for the canonical DealWatch Chrome instance.
DEALWATCH_BROWSER_IDENTITY_LABEL=
DEALWATCH_BROWSER_IDENTITY_ACCENT=
