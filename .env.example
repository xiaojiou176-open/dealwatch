DB_PATH=.legacy-runtime/data/dealwatch.db
DATABASE_URL=postgresql+psycopg://dealwatch:dealwatch@localhost:15432/dealwatch
RUNS_DIR=.runtime-cache/runs
REPORTS_DIR=.runtime-cache/runs/reports
STORAGE_STATE_DIR=.runtime-cache/cache/state
BACKUPS_DIR=.legacy-runtime/backups
LOGS_DIR=.runtime-cache/logs
OPERATOR_ARTIFACTS_DIR=.runtime-cache/operator
EXTERNAL_CACHE_DIR=~/.cache/dealwatch
BROWSER_DEBUG_BUNDLE_DIR=.runtime-cache/operator/browser-debug
LOG_MAX_BYTES=1000000
LOG_BACKUP_COUNT=5
LOG_RETENTION_DAYS=14
CACHE_BUDGET_BYTES=4294967296
ZIP_CODE=00000
OWNER_EMAIL=owner@example.com
OWNER_DISPLAY_NAME=DealWatch Owner
OWNER_BOOTSTRAP_TOKEN=change-me
POSTMARK_SERVER_TOKEN=
POSTMARK_WEBHOOK_TOKEN=
POSTMARK_FROM_EMAIL=dealwatch@example.com
POSTMARK_MESSAGE_STREAM=outbound
# Local-first defaults for the developer stack only.
# Real Render/live deployment values must use public HTTPS URLs instead of localhost.
APP_BASE_URL=http://127.0.0.1:8000
API_HOST=0.0.0.0
API_PORT=8000
WEBUI_DEV_URL=http://127.0.0.1:5173
# Temporary SQLite/bootstrap bridge only. Keep false for the PostgreSQL product runtime.
PRODUCT_AUTO_CREATE_SCHEMA=false
WORKER_POLL_SECONDS=60
MAINTENANCE_ENABLED=true
MAINTENANCE_HOUR_LOCAL=3
MAINTENANCE_MINUTE_LOCAL=15
DEFAULT_TASK_CADENCE_MINUTES=360
DEFAULT_NOTIFICATION_COOLDOWN_MINUTES=240
USE_LLM=false
LLM_API_KEY=
AI_PROVIDER=disabled
AI_MODEL=
AI_BASE_URL=
AI_SWITCHYARD_PROVIDER=
AI_SWITCHYARD_LANE=byok
AI_TIMEOUT_SECONDS=8.0
AI_COMPARE_EXPLAIN_ENABLED=false
AI_GROUP_EXPLAIN_ENABLED=false
AI_RECOVERY_COPILOT_ENABLED=false
SMTP_HOST=localhost
SMTP_USER=
SMTP_PASSWORD=
# Accepts a comma-separated string like `weee,ranch99` or a JSON array like `["weee","ranch99"]`
ENABLED_STORES=weee
PROXY_SERVER=
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_BLOCK_STYLESHEETS=true
CHROME_CDP_URL=http://127.0.0.1:9333
CHROME_REMOTE_DEBUG_PORT=9333
CHROME_USER_DATA_DIR=~/.cache/dealwatch/browser/chrome-user-data
CHROME_PROFILE_NAME=dealwatch
CHROME_PROFILE_DIRECTORY=Profile 21
CHROME_ATTACH_MODE=browser
# Optional human-facing browser lane identity hints for the canonical DealWatch Chrome instance.
DEALWATCH_BROWSER_IDENTITY_LABEL=
DEALWATCH_BROWSER_IDENTITY_ACCENT=
CHROME_START_URL=
CHROME_OBSERVE_MS=750
RULE_MIN_DROP_AMOUNT=0.05
RULE_MIN_DROP_PCT=1.0
VALIDATOR_MIN_PRICE=0.0
VALIDATOR_MAX_PRICE=1000.0
VALIDATOR_MIN_TITLE_LENGTH=6
PRICE_HISTORY_KEEP_DAYS=180
RUNS_KEEP_DAYS=30
REPORTS_KEEP_DAYS=30
BACKUPS_KEEP_DAYS=30
